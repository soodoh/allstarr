{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "types": ["bun", "node"],
    "paths": {
      "src/*": ["./src/*"]
    }
  },
  "include": ["src", "e2e", "vite.config.ts", "vitest.config.ts"]
}
